{
  "envId": "${CLOUDBASE_ENV_ID}",
  "functionRoot": "cloudfunctions",
  "functions": [
    {
      "name": "haohang-api",
      "timeout": 20,
      "runtime": "Nodejs18.15",
      "handler": "index.main"
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": ["cloudbaserc.json", "**/.*", "**/node_modules/**"]
  }
}
