# Cloudflare Pages 线上环境默认使用同域 /api，一般无需设置。
# 本地要联调 Pages Functions 时设置为 /api；留空则使用浏览器演示数据。
VITE_API_BASE_URL=/api

# 仅本地浏览器演示使用，正式管理员密码请配置为 Cloudflare Secret。
VITE_DEMO_ADMIN_PASSWORD=demo1234

# Cloudflare Pages Functions Secrets（不要把真实值写进本文件或提交到 Git）：
# ADMIN_PASSWORD_HASH=sha256-salted:<salt-base64>:<hash-base64>
# ADMIN_SESSION_SECRET=<long-random-string>
# DATA_ENCRYPTION_KEY=<32-byte-base64-key>
# DATA_HASH_SECRET=<long-random-string>
# WECOM_WEBHOOK_URL=<optional-enterprise-wechat-bot-webhook>
