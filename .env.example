# 留空时自动使用浏览器本地演示数据，便于预览。
VITE_CLOUDBASE_ENV_ID=
VITE_CLOUDBASE_FUNCTION_NAME=haohang-api

# 仅本地开发使用；正式环境的管理员密码由云函数环境变量管理。
VITE_DEMO_ADMIN_PASSWORD=demo1234

# CloudBase 云函数环境变量（不要提交真实值）：
# ADMIN_PASSWORD_HASH=<salt>:<scrypt hash>
# ADMIN_SESSION_SECRET=<long random string>
# DATA_ENCRYPTION_KEY=<32-byte base64 key>
# DATA_HASH_SECRET=<long random string>
# WECOM_WEBHOOK_URL=<enterprise wechat bot webhook>
